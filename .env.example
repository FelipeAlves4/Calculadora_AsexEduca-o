# Banco usado somente pelo comando npm run dev
LOCAL_DATABASE_URL=./data/asex.db

# Na Vercel, crie DATABASE_URL com a URI "Transaction pooler" exibida em Connect no Supabase:
# DATABASE_URL=postgresql://postgres.PROJECT_REF:[SUA-SENHA]@aws-0-REGIAO.pooler.supabase.com:6543/postgres

# Gere um segredo longo e aleatório antes de publicar
AUTH_SECRET=substitua-por-um-segredo-longo-e-aleatorio
APP_URL=https://calculadora-asex-educacao.vercel.app

# Envio de recuperação de senha pelo Resend (opcional)
EMAIL_FROM=
EMAIL_API_KEY=

# Administrador inicial, criado somente quando ainda não existe nenhum admin
BOOTSTRAP_ADMIN_NAME=Administrador ASEX
BOOTSTRAP_ADMIN_PHONE=11999999999
BOOTSTRAP_ADMIN_EMAIL=admin@seu-email.com
BOOTSTRAP_ADMIN_PASSWORD=substitua-por-uma-senha-forte
